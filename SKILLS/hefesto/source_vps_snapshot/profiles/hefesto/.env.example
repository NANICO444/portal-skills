# =============================================================================
# Hefesto — .env (template)
# Copiar pra ~/.hermes/profiles/hefesto/.env e preencher
# NUNCA commitar valores reais.
# =============================================================================

# ─── Inferência (provider primário OpenRouter) ────────────────────────────────
OPENROUTER_API_KEY=

# ─── Nous Portal OAuth (subagent revisor Qwen — opcional) ────────────────────
# Configurado via `hermes -p hefesto login`, sem chave manual
# NOUS_API_KEY=    # alternativa via API key (não usar OAuth)

# ─── Pesquisa ────────────────────────────────────────────────────────────────
TAVILY_API_KEY=                # 1 key (Hefesto tem cota menor)

# ─── Maton (integrações: GitHub, etc) ───────────────────────────────────────
MATON_API_KEY=

# ─── GitHub (PR workflow + repo management) ─────────────────────────────────
GITHUB_TOKEN=                  # PAT da conta Executores (compartilhada)

# ─── Discord (bot Hefesto) ──────────────────────────────────────────────────
DISCORD_BOT_TOKEN=             # bot dedicado #codigo-chat
# DISCORD_APP_ID=
# DISCORD_GUILD_ID=

# ─── Tirith (security scanning — opcional) ──────────────────────────────────
# Não requer chave — binary local

# ─── Browser automation (opcional — pra dogfood QA web) ─────────────────────
# BROWSERBASE_API_KEY=

# ─── Anti-padrões NUNCA aqui ────────────────────────────────────────────────
# NUNCA colocar:
# - HONCHO_API_KEY (Hefesto NÃO usa Honcho — D43, executores não têm memory cross-session)
# - Credenciais Apollo/Jarvis (Hefesto é executor compartilhado, contas separadas)
# - NOTION_API_KEY (Apollo só — Hefesto pergunta, não consulta KB)
# - Segredos dos pipelines (V6.2 licitacoes / V3.1 emails têm seus próprios .env)
# - Credentials de produção (Hefesto NÃO administra prod — handoff pro hermes-vps)
#
# Razão: 3 contas externas (Apollo individual, Jarvis individual, Executores
# compartilhada — Hefesto opera aqui). Hefesto é executor: contexto vem do card
# Kanban + workspace, não de memory cross-session. Segredos de prod ficam no
# hermes-vps que tem permissão sudo limitada e dupla confirmação obrigatória.
