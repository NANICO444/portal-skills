# =============================================================================
# Aurora — .env (template)
# Copiar pra ~/.hermes/profiles/aurora/.env e preencher
# NUNCA commitar valores reais.
# =============================================================================

# ─── Inferência (provider primário OpenRouter — tudo via OpenRouter) ─────────
OPENROUTER_API_KEY=

# ─── Pesquisa ────────────────────────────────────────────────────────────────
TAVILY_API_KEY=                # 1 key (Aurora tem cota menor que Apollo/Jarvis)

# ─── Maton (CRÍTICO — porta de entrada pra GitHub/Vercel/Drive/Notion) ──────
MATON_API_KEY=

# As conexões abaixo NÃO ficam aqui — são configuradas no painel Maton
# (https://maton.ai/dashboard) por OAuth e ficam atreladas à Conta Executores
# (compartilhada com Hefesto/hermes-vps/etc).
#
# Aurora consome via Maton Gateway:
#   - google-drive    → entregas finais
#   - github          → repos privados
#   - vercel          → deploy staging
#   - notion          → documentação visual
#   - netlify         → alternativa Vercel (opcional)
#   - cloudflare-pages → alternativa Vercel (opcional)
#
# Validar conexões antes de S3a:
# curl https://ctrl.maton.ai/connections?status=ACTIVE \
#   -H "Authorization: Bearer $MATON_API_KEY"

# ─── Discord (bot Aurora — canal #design-chat) ──────────────────────────────
DISCORD_BOT_TOKEN=
# DISCORD_APP_ID=
# DISCORD_GUILD_ID=

# ─── Tirith (security scanning — opcional mas recomendado) ──────────────────
# Não requer chave — binary local

# ─── Browser automation (Playwright via Maton OU local) ─────────────────────
# Aurora usa pra Playwright headless audit
# Se via cloud (Browserbase):
# BROWSERBASE_API_KEY=

# ─── Image gen (opcional — Aurora pode usar pra mockups visuais) ────────────
# FAL_KEY=                     # via fal.ai (alternativa local)
# Nota: ComfyUI cloud também opcional, mas pesado pra MVP

# ─── Anti-padrões NUNCA aqui ────────────────────────────────────────────────
# NUNCA colocar:
# - GITHUB_TOKEN direto (usar Maton OAuth)
# - VERCEL_TOKEN direto (usar Maton OAuth)
# - GOOGLE_API_KEY direto (usar Maton OAuth)
# - NOTION_API_KEY direto (usar Maton OAuth)
#
# Razão: Maton gerencia OAuth + rate limits + rotação automática.
# Se precisar acesso direto a alguma API (sem Maton), documentar
# motivo em DECISIONS.md do projeto.
