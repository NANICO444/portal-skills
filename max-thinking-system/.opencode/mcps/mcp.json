{
  "mcp": {
    "filesystem": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "C:/Users/User/Desktop/COISAS JOAO"],
      "description": "Acesso seguro a arquivos locais",
      "enabled": true
    },
    "github": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "description": "Integracao GitHub (issues, PRs, repos, actions)",
      "enabled": true,
      "env": { "GITHUB_TOKEN": "${env:GITHUB_TOKEN}" }
    },
    "git": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-git", "--repository", "C:/Users/User/Desktop/COISAS JOAO"],
      "description": "Git avancado (history, diff, blame, log)",
      "enabled": true
    },
    "fetch": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-fetch"],
      "description": "HTTP requests (GET/POST) com retry e auth",
      "enabled": true
    },
    "memory": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "description": "Grafo de conhecimento persistente",
      "enabled": true
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "description": "Raciocinio estruturado multi-step",
      "enabled": true
    },
    "puppeteer": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-puppeteer"],
      "description": "Browser automation para E2E e scraping",
      "enabled": true
    },
    "brave-search": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-brave-search"],
      "description": "Busca web via Brave (para o library-curator)",
      "enabled": false,
      "env": { "BRAVE_API_KEY": "${env:BRAVE_API_KEY}" }
    },
    "openrouter-mcp": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-openrouter"],
      "description": "Acesso a modelos via OpenRouter",
      "enabled": true,
      "env": { "OPENROUTER_API_KEY": "${env:OPENROUTER_API_KEY}" }
    },
    "npm": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-npm"],
      "description": "Consulta pacotes npm (para library-curator)",
      "enabled": true
    },
    "pypi": {
      "type": "stdio",
      "command": ["uvx", "mcp-server-pypi"],
      "description": "Consulta pacotes PyPI (para library-curator Python)",
      "enabled": true
    },
    "sentry": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sentry"],
      "description": "Sentry para tracking de erros em producao",
      "enabled": false,
      "env": { "SENTRY_DSN": "${env:SENTRY_DSN}" }
    },
    "postgres": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-postgres"],
      "description": "Acesso a banco Postgres para queries",
      "enabled": false,
      "env": { "DATABASE_URL": "${env:DATABASE_URL}" }
    },
    "sqlite": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sqlite"],
      "description": "SQLite local para testes",
      "enabled": true
    },
    "playwright": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-playwright"],
      "description": "Playwright para testes E2E robustos",
      "enabled": true
    }
  },
  "servers_config": {
    "auto_start": true,
    "restart_on_failure": true,
    "max_retries": 3,
    "health_check_interval_seconds": 30
  }
}
