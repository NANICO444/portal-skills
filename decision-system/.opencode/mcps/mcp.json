{
  "mcp": {
    "filesystem": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "C:/Users/User/Desktop/COISAS JOAO"],
      "description": "Acesso seguro a arquivos locais do projeto",
      "enabled": true,
      "env": {}
    },
    "github": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "description": "Integracao com GitHub (issues, PRs, repos)",
      "enabled": true,
      "env": {
        "GITHUB_TOKEN": "${env:GITHUB_TOKEN}"
      }
    },
    "git": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-git", "--repository", "C:/Users/User/Desktop/COISAS JOAO"],
      "description": "Operacoes git avancadas",
      "enabled": true
    },
    "fetch": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-fetch"],
      "description": "HTTP requests (GET, POST) com tratamento de erros",
      "enabled": true
    },
    "memory": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "description": "Grafo de conhecimento persistente entre sessoes",
      "enabled": true
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "description": "Raciocinio estruturado multi-step para decisoes",
      "enabled": true
    },
    "puppeteer": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-puppeteer"],
      "description": "Browser automation (testes E2E, scraping)",
      "enabled": false
    },
    "brave-search": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-brave-search"],
      "description": "Busca web via Brave (requer API key)",
      "enabled": false,
      "env": {
        "BRAVE_API_KEY": "${env:BRAVE_API_KEY}"
      }
    },
    "openrouter-mcp": {
      "type": "stdio",
      "command": ["npx", "-y", "@modelcontextprotocol/server-openrouter"],
      "description": "Acesso a modelos via OpenRouter",
      "enabled": true,
      "env": {
        "OPENROUTER_API_KEY": "${env:OPENROUTER_API_KEY}"
      }
    }
  },
  "servers_config": {
    "auto_start": true,
    "restart_on_failure": true,
    "max_retries": 3
  }
}
